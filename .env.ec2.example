MYSQL_ROOT_PASSWORD=replace-with-a-strong-mysql-root-password
JWT_SECRET=replace-with-a-long-random-jwt-secret

# Use your EC2 public IPv4 DNS, public IP, or a domain pointed to the EC2 instance.
# Examples:
# PUBLIC_WEB_ORIGIN=http://13.213.10.20
# PUBLIC_WEB_ORIGIN=http://ec2-13-213-10-20.ap-southeast-1.compute.amazonaws.com
# PUBLIC_WEB_ORIGIN=https://commerce.example.com
PUBLIC_WEB_ORIGIN=http://replace-with-ec2-public-host

# The EC2 nginx frontend proxies /api/* to gateway-service inside Docker.
PUBLIC_API_BASE_URL=/api
WEB_PORT=80
