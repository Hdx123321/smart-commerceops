MYSQL_ROOT_PASSWORD=replace-with-a-strong-mysql-root-password
JWT_SECRET=replace-with-a-long-random-jwt-secret
PAYMENT_INTERNAL_TOKEN=replace-with-a-long-random-internal-service-token

# Use your Droplet public IP or a domain pointed to the Droplet.
# Examples:
# PUBLIC_WEB_ORIGIN=http://203.0.113.10
# PUBLIC_WEB_ORIGIN=https://commerce.example.com
PUBLIC_WEB_ORIGIN=http://replace-with-droplet-public-host

# The frontend nginx container proxies /api/* to gateway-service inside Docker.
PUBLIC_API_BASE_URL=/api
WEB_PORT=80

# Optional: leave LLM_API_KEY empty to run assistant fallback behavior only.
LLM_API_BASE_URL=https://api.deepseek.com
LLM_API_KEY=
LLM_MODEL=deepseek-v4-flash
