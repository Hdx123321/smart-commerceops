AWS_REGION=ap-southeast-1
APP_DOMAIN=app.example.com
API_DOMAIN=api.example.com
ECS_CLUSTER=smart-commerceops
ECS_EXECUTION_ROLE_ARN=arn:aws:iam::<account-id>:role/smart-commerceops-ecs-execution-role
ECS_TASK_ROLE_ARN=arn:aws:iam::<account-id>:role/smart-commerceops-ecs-task-role
DB_HOST=smart-commerceops-db.xxxxxx.ap-southeast-1.rds.amazonaws.com
DB_USERNAME=admin
REDIS_HOST=smart-commerceops-redis.xxxxxx.cache.amazonaws.com
DB_PASSWORD_SECRET_ARN=arn:aws:secretsmanager:ap-southeast-1:<account-id>:secret:smart-commerceops/db-password
JWT_SECRET_ARN=arn:aws:secretsmanager:ap-southeast-1:<account-id>:secret:smart-commerceops/jwt-secret
