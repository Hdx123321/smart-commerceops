{
  "family": "catalog-service",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "__ECS_EXECUTION_ROLE_ARN__",
  "taskRoleArn": "__ECS_TASK_ROLE_ARN__",
  "containerDefinitions": [
    {
      "name": "catalog-service",
      "image": "__IMAGE__",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8093,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "JAVA_TOOL_OPTIONS", "value": "-XX:MaxRAMPercentage=75" },
        { "name": "SPRING_DATASOURCE_URL", "value": "jdbc:mysql://__DB_HOST__:3306/catalog_db?useSSL=true&allowPublicKeyRetrieval=false" },
        { "name": "SPRING_DATASOURCE_USERNAME", "value": "__DB_USERNAME__" },
        { "name": "SPRING_DATA_REDIS_HOST", "value": "__REDIS_HOST__" },
        { "name": "SPRING_DATA_REDIS_PORT", "value": "6379" },
        { "name": "CATALOG_CACHE_TTL", "value": "5m" },
        { "name": "APP_UPLOAD_DIR", "value": "/tmp/uploads" }
      ],
      "secrets": [
        { "name": "SPRING_DATASOURCE_PASSWORD", "valueFrom": "__DB_PASSWORD_SECRET_ARN__" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/smart-commerceops/catalog-service",
          "awslogs-region": "__AWS_REGION__",
          "awslogs-stream-prefix": "ecs",
          "awslogs-create-group": "true"
        }
      }
    }
  ]
}
