{
  "family": "analytics-service",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "__ECS_EXECUTION_ROLE_ARN__",
  "taskRoleArn": "__ECS_TASK_ROLE_ARN__",
  "containerDefinitions": [
    {
      "name": "analytics-service",
      "image": "__IMAGE__",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8095,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "JAVA_TOOL_OPTIONS", "value": "-XX:MaxRAMPercentage=75" },
        { "name": "CATALOG_SERVICE_URL", "value": "http://catalog-service.commerceops.local:8093" },
        { "name": "ORDER_SERVICE_URL", "value": "http://order-service.commerceops.local:8094" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/smart-commerceops/analytics-service",
          "awslogs-region": "__AWS_REGION__",
          "awslogs-stream-prefix": "ecs",
          "awslogs-create-group": "true"
        }
      }
    }
  ]
}
